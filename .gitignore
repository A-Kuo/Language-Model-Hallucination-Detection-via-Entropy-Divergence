MANIFEST

# Secrets and credentials (defense in depth)
.env
.env.*
*.pem
*.key
secrets/
credentials.json
token.json
*.p12
*.pfx

# API keys and tokens (never commit these)
*api_key*
*apikey*
*api-token*
*apitoken*

# IDE
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
